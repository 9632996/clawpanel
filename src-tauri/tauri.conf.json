{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "decorations": true,
        "height": 700,
        "minHeight": 500,
        "minWidth": 800,
        "resizable": true,
        "title": "智爪平台",
        "width": 1100
      }
    ],
    "withGlobalTauri": true
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "SimpChinese",
          "English"
        ]
      },
      "webviewInstallMode": {
        "silent": true,
        "type": "embedBootstrapper"
      }
    }
  },
  "identifier": "com.aizuopin.zhizhua.workbench",
  "productName": "智爪平台",
  "version": "0.17.0"
}
